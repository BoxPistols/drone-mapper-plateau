# Cesium Ion トークン（3D地形・衛星写真）
VITE_CESIUM_TOKEN=your_cesium_ion_token

# ── AI アシスタント（無料枠: アプリ側キー） ──

# OpenAI API キー — GPT-5.4 nano（無料デフォルト）
# 取得: https://platform.openai.com/
VITE_OPENAI_API_KEY=sk-...

# Google Gemini API キー — Gemini 2.5 Flash（無料）
# 取得: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=

# ⚠️ 上記はデモ用途。本番ではserver-side proxyを使用すること
# GPT-5.4 mini はユーザーが自身のAPIキーをUI上で入力して利用
